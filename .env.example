VITE_SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
VITE_CHANNEL_PLUGIN_KEY=YOUR_CHANNELTALK_PLUGIN_KEY

# Vercel Serverless API / Minecraft Mod API
# SUPABASE_URL may be omitted if VITE_SUPABASE_URL is set in Vercel env.
SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
DDINGPLUG_MOD_API_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET

# [SECURITY] API CORS 허용 도메인 (배포 후 반드시 설정)
# 예: https://dding-plug.vercel.app
# 미설정 시 localhost만 허용됨 (프로덕션에서 API가 막힐 수 있음)
DDINGPLUG_ALLOWED_ORIGIN=https://YOUR_DEPLOYED_DOMAIN

# Public mod update API defaults
DDINGPLUG_MOD_LATEST_VERSION=0.6.7
DDINGPLUG_MOD_MINECRAFT_VERSION=1.21.4
DDINGPLUG_MOD_FABRIC_LOADER=0.16.10+
DDINGPLUG_MOD_FABRIC_API=0.119.2+1.21.4
DDINGPLUG_MOD_DOWNLOAD_URL=https://ddingplug.vercel.app/download
DDINGPLUG_MOD_RELEASE_NOTE=업데이트 확인 UI 추가
DDINGPLUG_MOD_REQUIRED=false
