VITE_SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Vercel Serverless API / Minecraft Mod API
# SUPABASE_URL may be omitted if VITE_SUPABASE_URL is set in Vercel env.
SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
DDINGPLUG_MOD_API_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET

# [SECURITY] API CORS 허용 도메인 (배포 후 반드시 설정)
# 예: https://dding-plug.vercel.app
# 미설정 시 localhost만 허용됨 (프로덕션에서 API가 막힐 수 있음)
DDINGPLUG_ALLOWED_ORIGIN=https://YOUR_DEPLOYED_DOMAIN
